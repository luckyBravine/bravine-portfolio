{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://portfolio.example.com/schemas/technology-graph.schema.json",
  "title": "Technology Graph Schema",
  "description": "Schema for validating technology graph configuration files",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "description": "Array of technology nodes in the graph",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "proficiency"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the node",
            "minLength": 1,
            "maxLength": 50
          },
          "name": {
            "type": "string",
            "description": "Display name of the technology",
            "minLength": 1,
            "maxLength": 100
          },
          "category": {
            "type": "string",
            "description": "Category classification of the technology",
            "enum": ["language", "framework", "tool", "platform", "database", "cloud"]
          },
          "proficiency": {
            "type": "number",
            "description": "Proficiency level from 0 to 100",
            "minimum": 0,
            "maximum": 100
          },
          "description": {
            "type": "string",
            "description": "Optional detailed description of the technology",
            "maxLength": 500
          },
          "icon": {
            "type": "string",
            "description": "Optional icon identifier or path",
            "maxLength": 200
          },
          "color": {
            "type": "string",
            "description": "Optional hex color code for visualization",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "description": "Array of connection edges between nodes",
      "items": {
        "type": "object",
        "required": ["source", "target", "strength"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Source node ID",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "description": "Target node ID",
            "minLength": 1
          },
          "strength": {
            "type": "number",
            "description": "Connection strength from 0 to 1",
            "minimum": 0,
            "maximum": 1
          },
          "type": {
            "type": "string",
            "description": "Optional relationship type",
            "enum": ["uses", "related", "alternative"]
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the graph",
      "properties": {
        "version": {
          "type": "string",
          "description": "Version of the graph configuration",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "lastUpdated": {
          "type": "string",
          "description": "ISO 8601 timestamp of last update",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
